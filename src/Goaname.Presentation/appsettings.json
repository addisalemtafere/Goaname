{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Postgres": "",
    "Redis": ""
  },
  "OpenIddict": {
    "TokenLifetimeHours": 8,
    "SpaClientId": "goaname-spa"
  },
  "Authentication": {
    "JwtBearer": {
      "AllowLocalAccounts": false
    }
  },
  "Orleans": {
    "ClusterId": "goaname",
    "ServiceId": "goaname",
    "Clustering": {
      "ProviderType": "Redis"
    },
    "Reminders": {
      "ProviderType": "AdoNet",
      "Invariant": "Npgsql"
    },
    "GrainStorage": {
      "GoanameStore": {
        "ProviderType": "AdoNet",
        "Invariant": "Npgsql"
      }
    }
  },
  "Goaname": {
    "Orleans": {
      "Transactions": {
        "Enabled": true
      },
      "Dashboard": {
        "Enabled": false,
        "RoutePrefix": "/orleans",
        "CounterUpdateIntervalMs": 1000,
        "RequireAuthorization": true
      }
    }
  }
}
