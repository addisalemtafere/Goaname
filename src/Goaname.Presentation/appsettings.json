{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Orleans": "Information"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "OrleansStorage": "Host=localhost;Port=5432;Database=goaname;Username=goaname;Password=goaname",
    "OrleansReminders": "Host=localhost;Port=5432;Database=goaname;Username=goaname;Password=goaname"
  },
  "Authentication": {
    "JwtBearer": {
      "Authority": "https://your-identity-server",
      "Audience": "goaname",
      "RequireHttpsMetadata": true,
      "UseDevelopmentKey": false
    }
  },
  "Orleans": {
    "Clustering": {
      "Provider": "Redis",
      "RedisConnectionString": "localhost:6379"
    },
    "Storage": {
      "Provider": "AdoNet",
      "ConnectionString": "Host=localhost;Port=5432;Database=goaname;Username=goaname;Password=goaname",
      "Invariant": "Npgsql"
    },
    "Reminders": {
      "Provider": "AdoNet",
      "ConnectionString": "Host=localhost;Port=5432;Database=goaname;Username=goaname;Password=goaname",
      "Invariant": "Npgsql"
    },
    "Transactions": {
      "Enabled": true
    },
    "Dashboard": {
      "Enabled": true,
      "RoutePrefix": "/orleans",
      "CounterUpdateIntervalMs": 1000,
      "RequireAuthorization": true
    }
  }
}
