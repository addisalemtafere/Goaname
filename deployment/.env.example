# Copy to .env and set real values. Never commit .env with secrets.
#
# ASP.NET Core environment
ASPNETCORE_ENVIRONMENT=Production

# Database (matches deployment/docker-compose.yml service names when deployed together)
ConnectionStrings__Postgres=Host=postgres;Port=5432;Database=goaname;Username=goaname;Password=CHANGE_ME
ConnectionStrings__Redis=redis:6379

# Orleans cluster identity (must be stable across deployments)
Orleans__ClusterId=goaname
Orleans__ServiceId=goaname

# JWT (production identity provider)
Authentication__JwtBearer__Authority=https://your-identity-server
Authentication__JwtBearer__Audience=goaname
